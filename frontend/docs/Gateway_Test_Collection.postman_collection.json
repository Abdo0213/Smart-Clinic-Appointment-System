						"auth": {
							"type": "bearer",
							"bearer": [{"key": "token", "value": "{{doctor_token}}", "type": "string"}]
						},
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"medicationName\": \"Amlodipine\",\n  \"dosage\": \"5mg\",\n  \"frequency\": \"Once daily\",\n  \"durationDays\": 30,\n  \"notes\": \"Take in the morning with food\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/visits/<REPLACE_WITH_VISIT_ID>/prescriptions",
