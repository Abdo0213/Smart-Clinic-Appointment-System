						"body": {
							"mode": "raw",
							"raw": "{\n    \"patientId\": \"<REPLACE_WITH_PATIENT_ID>\",\n    \"doctorId\": \"<REPLACE_WITH_DOCTOR_ID>\",\n    \"slotDate\": \"2026-04-20\",\n    \"slotStart\": \"10:00:00\",\n    \"slotEnd\": \"10:30:00\"\n}"
