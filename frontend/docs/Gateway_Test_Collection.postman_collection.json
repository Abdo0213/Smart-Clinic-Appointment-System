						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"date\": \"2026-04-27\",\n    \"startTime\": \"09:00:00\",\n    \"endTime\": \"17:00:00\",\n    \"slotDuration\": 30,\n    \"price\": 100.0,\n    \"breaks\": [\n        {\n            \"breakStart\": \"12:00:00\",\n            \"breakEnd\": \"13:00:00\"\n        }\n    ]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/doctors/<REPLACE_WITH_DOCTOR_ID>/schedules",
							"host": ["{{baseUrl}}"],
							"path": ["api", "doctors", "<REPLACE_WITH_DOCTOR_ID>", "schedules"]
						}
					}
				},
				{
