		{
			"name": "6. Billing Capabilities",
			"item": [
				{
					"name": "Create Invoice (Admin/Receptionist)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]
						},
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"visitId\": \"<REPLACE_WITH_VISIT_ID>\",\n    \"patientId\": \"<REPLACE_WITH_PATIENT_ID>\",\n    \"appointmentId\": \"<REPLACE_WITH_APPOINTMENT_ID>\",\n    \"lineItems\": [\n        {\n            \"description\": \"Consultation Fee\",\n            \"quantity\": 1,\n            \"unitPrice\": 500.00\n        },\n        {\n            \"description\": \"ECG\",\n            \"quantity\": 1,\n            \"unitPrice\": 150.00\n        }\n    ]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/billing/invoices",
							"host": ["{{baseUrl}}"],
							"path": ["api", "billing", "invoices"]
						}
					}
				},
				{
					"name": "Get Patient Invoices (Receptionist/Admin)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]
						},
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/billing/invoices?patientId=<REPLACE_WITH_PATIENT_ID>",
							"host": ["{{baseUrl}}"],
							"path": ["api", "billing", "invoices"],
							"query": [
								{
									"key": "patientId",
									"value": "<REPLACE_WITH_PATIENT_ID>"
								}
							]
						}
					}
				},
				{
					"name": "Mark Invoice as Paid (Receptionist/Admin)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]
						},
						"method": "PATCH",
						"url": {
							"raw": "{{baseUrl}}/api/billing/invoices/<REPLACE_WITH_INVOICE_ID>/pay",
							"host": ["{{baseUrl}}"],
							"path": ["api", "billing", "invoices", "<REPLACE_WITH_INVOICE_ID>", "pay"]
						}
					}
				}
