						"body": {
							"mode": "raw",
							"raw": "{\n  \"additionalItems\": [\n    {\n      \"description\": \"X-Ray - Chest\",\n      \"quantity\": 1,\n      \"unitPrice\": 50.0\n    },\n    {\n      \"description\": \"Wound Dressing\",\n      \"quantity\": 1,\n      \"unitPrice\": 20.0\n    }\n  ]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/visits/<REPLACE_WITH_VISIT_ID>/sign",
