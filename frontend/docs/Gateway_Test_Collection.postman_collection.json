		{
			"name": "3. Doctor Capabilities",
			"item": [
				{
					"name": "Get Doctor Profile",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{"key": "token", "value": "{{doctor_token}}", "type": "string"}]
						},
						"method": "GET",
